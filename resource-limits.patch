+    // Calculate message size (JSON representation)
+    const messageSize = Buffer.byteLength(content, "utf-8") +
+                        (subject ? Buffer.byteLength(subject, "utf-8") : 0);
+
+    // Check individual message size
+    if (messageSize > MAX_MESSAGE_SIZE) {
+      throw new Error(
+        `Message exceeds maximum size of ${MAX_MESSAGE_SIZE} bytes (${Math.ceil(MAX_MESSAGE_SIZE / 1024)} KB). ` +
+        `Your message is ${messageSize} bytes (${Math.ceil(messageSize / 1024)} KB).`
+      );
+    }
+
+    // Check subject length
+    if (subject && subject.length > MAX_SUBJECT_LENGTH) {
+      throw new Error(
+        `Subject exceeds maximum length of ${MAX_SUBJECT_LENGTH} characters. ` +
+        `Your subject is ${subject.length} characters.`
+      );
+    }
+
+    // Check total storage limit
+    if (this.metrics.total_storage_bytes + messageSize > MAX_TOTAL_STORAGE) {
+      const usedGB = (this.metrics.total_storage_bytes / (1024 * 1024 * 1024)).toFixed(2);
+      const maxGB = (MAX_TOTAL_STORAGE / (1024 * 1024 * 1024)).toFixed(2);
+      throw new Error(
+        `Storage limit exceeded. Maximum ${maxGB} GB allowed. ` +
+        `Currently using ${usedGB} GB. Please delete old messages to free space.`
+      );
+    }
+  }
