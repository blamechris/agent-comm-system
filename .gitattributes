# Enforce LF line endings on all text files
* text=auto eol=lf

# Explicitly declare files that should always have LF
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
